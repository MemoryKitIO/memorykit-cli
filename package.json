{
  "name": "@memorykitio/cli",
  "version": "0.1.0",
  "description": "Official CLI for MemoryKit — memory infrastructure for AI applications",
  "author": "MemoryKit",
  "license": "MIT",
  "homepage": "https://memorykit.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/MemoryKitIO/memorykit-cli.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "memorykit": "./bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "oclif": {
    "bin": "memorykit",
    "dirname": "memorykit",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Register, login, and manage authentication"
      },
      "company": {
        "description": "Create and manage companies"
      },
      "project": {
        "description": "Create and manage projects"
      },
      "apikey": {
        "description": "Create, list, and revoke API keys"
      },
      "memories": {
        "description": "Create, search, upload, and manage memories"
      },
      "config": {
        "description": "View and modify CLI configuration"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "prepack": "npm run clean && npm run build && oclif manifest",
    "postpack": "rm -f oclif.manifest.json"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@oclif/core": "^4.0.0",
    "@memorykitio/sdk": "file:../MemoryKit-TypeScript-SDK"
  },
  "devDependencies": {
    "@oclif/test": "^4.0.0",
    "oclif": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
